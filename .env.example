# ===== IA: Cerebras (backend local y funciones serverless de Vercel) =====
# API Key de Cerebras (modelo de IA). Gratis en https://cloud.cerebras.ai/
# Es OPCIONAL aquí: también puedes ingresarla desde la pantalla "Configuración".
CEREBRAS_API_KEY=tu_api_key_de_cerebras_aqui

# (Opcional) Modelo de Cerebras. Por defecto "llama-3.3-70b".
# CEREBRAS_MODEL=llama-3.3-70b

# ===== Búsqueda web: Tavily =====
# API Key de Tavily para precios/reportes en tiempo real. Gratis en https://app.tavily.com/
# Sin ella, la IA responde con estimados (sin búsqueda web en vivo).
TAVILY_API_KEY=tu_api_key_de_tavily_aqui

# (Opcional) Puerto del backend local. Por defecto 3001.
# PORT=3001

# ===== Frontend (Vite) — solo para desarrollo local avanzado =====
# (Opcional) URL del backend. En producción (Vercel) se usan rutas relativas automáticamente.
# VITE_API_URL=http://localhost:3001
# (Opcional) URL del servidor de WebSockets (tiempo real). Vacío = desactivado.
# VITE_SOCKET_URL=http://localhost:3001
