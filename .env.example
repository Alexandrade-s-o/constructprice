# ===== Groq (backend local y funciones serverless de Vercel) =====
# Tu API Key de Groq. Consíguela gratis en https://console.groq.com/keys
# Es OPCIONAL: también puedes ingresarla desde la pantalla "Configuración" de la app.
GROQ_API_KEY=tu_api_key_de_groq_aqui

# (Opcional) Modelo de Groq a usar. Por defecto "groq/compound" (con búsqueda web en vivo).
# GROQ_MODEL=groq/compound

# (Opcional) Puerto del backend local. Por defecto 3001.
# PORT=3001

# ===== Frontend (Vite) — solo para desarrollo local avanzado =====
# (Opcional) URL del backend. En producción (Vercel) se usan rutas relativas automáticamente.
# VITE_API_URL=http://localhost:3001
# (Opcional) URL del servidor de WebSockets (tiempo real). Vacío = desactivado.
# VITE_SOCKET_URL=http://localhost:3001
